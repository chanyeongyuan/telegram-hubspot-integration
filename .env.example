# Public URL where this service is reachable over HTTPS.
# On Render, this can be left blank because the app uses RENDER_EXTERNAL_URL.
PUBLIC_BASE_URL=https://your-service.example.com
PORT=3000

# Keep this on durable storage in production.
STATE_FILE_PATH=./data/state.json

# Telegram Bot API. Create the bot in BotFather and connect it to the
# Telegram Business account as a connected business bot.
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-secret
TELEGRAM_BUSINESS_ACCOUNT_NAME=Your Telegram Business

# HubSpot portal and public app.
HUBSPOT_PORTAL_ID=50444105
HUBSPOT_APP_ID=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_DEVELOPER_API_KEY=

# Use either a static OAuth access token for initial testing, or complete
# /hubspot/oauth/start after deploying the service.
HUBSPOT_ACCESS_TOKEN=

# Filled after running npm run setup:hubspot-channel.
HUBSPOT_CHANNEL_ID=
HUBSPOT_CHANNEL_NAME=Telegram Business
HUBSPOT_CHANNEL_DESCRIPTION=Route Telegram Business 1:1 enquiries into HubSpot.
HUBSPOT_CHANNEL_LOGO_URL=

# Use this for direct channel-account creation. If you use the HubSpot setup
# popup flow instead, the service stores channel-account IDs from webhooks.
HUBSPOT_INBOX_ID=
HUBSPOT_CHANNEL_ACCOUNT_ID=
TELEGRAM_BUSINESS_CONNECTION_ID=
